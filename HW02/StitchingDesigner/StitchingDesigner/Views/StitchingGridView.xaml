<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StitchingDesigner.ViewModels"
             xmlns:models="clr-namespace:StitchingDesigner.Models"
             x:Class="StitchingDesigner.Views.StitchingGridView"
             x:Name="RootPage"
             Title="Stitching Designer">
    <ContentPage.BindingContext>
        <vm:GridViewModel />
    </ContentPage.BindingContext>

    <Grid Padding="12" ColumnDefinitions="260,*" ColumnSpacing="12">
        <VerticalStackLayout Grid.Column="0" Spacing="25">
            <VerticalStackLayout Spacing="10">
                <Label Text="Grid Size" FontSize="Title"/>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Entry Grid.Column="0" Placeholder="Rows" Text="{Binding EntryRowCount}"/>
                    <Entry Grid.Column="1" Placeholder="Columns" Text="{Binding EntryColumnCount}"/>
                </Grid>
                <Button
                    Text="Set"
                    Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SetSizeCommand}"/>
            </VerticalStackLayout>
            
            <VerticalStackLayout Spacing="12">
                <Label Text="Floss" FontSize="Title"/>
                <SearchBar Placeholder="Search by ID or name"
                            Text="{Binding Pallete.SearchText}" />
                <CollectionView ItemsSource="{Binding Pallete.SearchResults}"
                                HeightRequest="220"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FlossModel">
                            <Button Padding="8,4"
                                    Margin="0,2"
                                    HorizontalOptions="Fill"
                                    Text="{Binding Description}"
                                    TextColor="Black"
                                    BackgroundColor="{Binding DisplayColor}"
                                    Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.Pallete.SelectFlossCommand}"
                                    CommandParameter="{Binding .}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label Margin="0, 10, 0, 0" Text="Currently Selected" HorizontalOptions="Center"/>
                <Button HorizontalOptions="Fill"
                        Text="{Binding Pallete.SelectedFloss.Description}"
                        TextColor="Black"
                        BackgroundColor="{Binding Pallete.SelectedFloss.DisplayColor}"/>
            </VerticalStackLayout>
            
            <VerticalStackLayout Spacing="12">
                <Label Text="Save/Load" FontSize="Title"/>
                <Entry Placeholder="Choose a pattern name"
                       Text="{Binding PatternName}"/>
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="Save"
                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SavePatternCommand}"/>
                    <Button Grid.Column="1"
                            Text="Load"
                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.LoadPatternCommand}"/>
                </Grid>
                <Label Text="{Binding LastSavedFilePath}" TextColor="Gray" LineBreakMode="CharacterWrap"/>
            </VerticalStackLayout>
        </VerticalStackLayout>

        <Grid Grid.Column="1"
            x:Name="GridViewport"
            SizeChanged="OnGridViewportSizeChanged">
            <CollectionView ItemsSource="{Binding Cells}"
                        SelectionMode="None"
                        WidthRequest="{Binding GridWidth}"
                        HeightRequest="{Binding GridHeight}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                    Span="{Binding GridSpan}"
                                    HorizontalItemSpacing="0"
                                    VerticalItemSpacing="0" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:GridCellViewModel">
                        <Button WidthRequest="{Binding Source={x:Reference RootPage}, Path=BindingContext.CellSize}"
                            HeightRequest="{Binding Source={x:Reference RootPage}, Path=BindingContext.CellSize}"
                            Padding="0"
                            Margin="0"
                            CornerRadius="0"
                            BorderColor="Gray"
                            BorderWidth="0.5"
                            FontSize="10"
                            Text="{Binding Label}"
                            BackgroundColor="{Binding Floss.DisplayColor, TargetNullValue='White'}"
                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.CellClickedCommand}"
                            CommandParameter="{Binding .}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>